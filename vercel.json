{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.6"
    }
  },
  "routes": [
    {
      "src": "/(assets|css|js|images)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/contact.php",
      "dest": "/api/contact.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
